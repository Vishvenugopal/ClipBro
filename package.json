{
  "name": "clipbro",
  "version": "1.0.0",
  "description": "ClipBro - Your intelligent clipboard companion with AI features & Screenshot manager for Windows",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --win",
    "pack": "electron-builder --dir"
  },
  "author": "UniversalClipboard",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "sql.js": "^1.9.0",
    "jimp": "^0.22.10",
    "qrcode": "^1.5.3",
    "jsqr": "^1.4.0",
    "tesseract.js": "^5.0.4",
    "uuid": "^9.0.0",
    "express": "^4.18.2"
  },
  "build": {
    "appId": "com.clipbro.app",
    "productName": "ClipBro",
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false
    },
    "files": [
      "electron/**/*",
      "src/**/*",
      "assets/**/*",
      "index.html"
    ]
  }
}
