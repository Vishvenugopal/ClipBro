{
  "name": "clipbro",
  "version": "1.0.0",
  "description": "ClipBro - Your intelligent clipboard companion with AI features & Screenshot manager for Windows",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --win --dir && node scripts/fix-icon.js && electron-builder --win --prepackaged dist/win-unpacked",
    "pack": "electron-builder --dir"
  },
  "author": "UniversalClipboard",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "electron-icon-builder": "^2.0.1",
    "rcedit": "^5.0.2"
  },
  "dependencies": {
    "express": "^4.18.2",
    "jimp": "^0.22.10",
    "jsqr": "^1.4.0",
    "qrcode": "^1.5.3",
    "sql.js": "^1.9.0",
    "tesseract.js": "^5.0.4",
    "uuid": "^9.0.0"
  },
  "build": {
    "appId": "com.clipbro.app",
    "productName": "ClipBro",
    "icon": "assets/clipbro-icons/icon.ico",
    "win": {
      "target": ["nsis", "appx"],
      "signAndEditExecutable": false,
      "icon": "assets/clipbro-icons/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false
    },
    "appx": {
      "identityName": "REPLACE_WITH_YOUR_IDENTITY",
      "publisher": "CN=1AF38139-DE96-4FEF-B4AD-AA6B6B202BEC",
      "publisherDisplayName": "REPLACE_WITH_YOUR_NAME",
      "applicationId": "ClipBro Manager",
      "displayName": "ClipBro Manager",
      "languages": ["en-US"],
      "backgroundColor": "#0d0d0d"
    },
    "files": [
      "electron/**/*",
      "src/**/*",
      "assets/**/*",
      "index.html",
      "eng.traineddata"
    ],
    "extraResources": [
      {
        "from": "eng.traineddata",
        "to": "eng.traineddata"
      }
    ]
  }
}
